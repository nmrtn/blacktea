# Copy to .env and fill in.

# The agent's wallet. Must hold Base Sepolia ETH (for gas) and USDC.
# Use the same wallet as the x402-quickstart for consistency.
EVM_PRIVATE_KEY=0x...

# Your Anthropic API key. If you already have ANTHROPIC_API_KEY in your
# shell env (Claude Code users likely do), this is optional.
# ANTHROPIC_API_KEY=sk-ant-...

# Where the agent should look for the paid resource. Defaults to the
# quickstart seller. Make sure that is running on the same port.
TARGET_URL=http://localhost:4021/protected
