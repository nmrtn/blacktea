# Copy to .env and fill in.

# Buyer wallet. Needs Base Sepolia testnet ETH (for gas) and testnet USDC.
# Get both from the Coinbase Developer Platform faucet.
EVM_PRIVATE_KEY=0x...

# Seller's receiving address. Where USDC payments land. Any Base Sepolia
# address works for the test. If you generate this in CDP, use that.
SELLER_RECEIVING_ADDRESS=0x...

# Coinbase facilitator URL on Base Sepolia. Default is correct.
FACILITATOR_URL=https://x402.coinbase.com

# Seller port. Default is fine.
SELLER_PORT=4021
